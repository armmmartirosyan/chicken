/**
 * VFX Assets - Confetti Spritesheet Data
 *
 * This file contains placeholder slots for confetti animation assets.
 *
 * INSTRUCTIONS FOR ASSET INTEGRATION:
 * ------------------------------------
 * 1. Export confetti spritesheet from animation software (e.g., After Effects)
 * 2. Convert PNG to Base64: `base64 confetti.png > confetti.txt`
 * 3. Paste Base64 string into CONFETTI_SPRITESHEET.imageBase64
 * 4. Fill in frameWidth and frameHeight based on your spritesheet dimensions
 * 5. Convert audio files to Base64 and paste into CONFETTI_AUDIO fields
 *
 * SPRITESHEET REQUIREMENTS:
 * - Format: PNG with transparency
 * - Frames: 40 total frames (arranged in grid)
 * - Frame order: Left-to-right, top-to-bottom (standard spritesheet layout)
 * - Recommended size: 1920x1080 per frame (fullscreen @ 1080p)
 *
 * AUDIO REQUIREMENTS:
 * - Format: MP3 or WAV (MP3 recommended for size)
 * - confettiSfx: Short burst sound (~1 second)
 * - victorySfx: Triumph melody (~2-3 seconds)
 */

// Confetti spritesheet configuration
export const CONFETTI_SPRITESHEET = {
  /**
   * Base64-encoded PNG spritesheet
   * Contains 40 frames of confetti animation
   *
   * EMPTY SLOT - USER MUST FILL THIS
   * Example format: "iVBORw0KGgoAAAANSUhEUgAA..."
   */
  imageBase64:
    "data:image/webp;base64,",

  /**
   * Width of each individual frame in pixels
   *
   * EMPTY SLOT - USER MUST FILL THIS
   * Example: 1920 (for fullscreen 1080p width)
   */
  frameWidth: 270,

  /**
   * Height of each individual frame in pixels
   *
   * EMPTY SLOT - USER MUST FILL THIS
   * Example: 1080 (for fullscreen 1080p height)
   */
  frameHeight: 480,

  /**
   * Total number of frames in the spritesheet
   * DO NOT MODIFY - Animation expects exactly 40 frames
   */
  frameCount: 40,

  /**
   * Animation playback speed in frames per second
   * DO NOT MODIFY - Matches source implementation
   */
  frameRate: 28,
};

// Confetti audio configuration
export const CONFETTI_AUDIO = {
  confettiSfxBase64:
    "data:audio/mp3;base64,",

  victorySfxBase64:
    "data:audio/mp3;base64,",
};

// Coin celebration spritesheet configuration (PLACEHOLDER - Empty until assets provided)
export const COIN_SPRITESHEET = {
  /**
   * Base64-encoded coin animation spritesheet (WebP recommended)
   * Format: "data:image/webp;base64,..."
   * PLACEHOLDER - Replace with actual coin animation spritesheet
   */
  imageBase64:
    "data:image/webp;base64,",

  /**
   * Width of each frame in pixels
   * Must match the actual spritesheet frame dimensions
   */
  frameWidth: 0,

  /**
   * Height of each frame in pixels
   * Must match the actual spritesheet frame dimensions
   */
  frameHeight: 0,

  /**
   * Total number of frames in the coin animation spritesheet
   * Update when replacing placeholder with actual asset
   */
  frameCount: 0,

  /**
   * Animation playback speed in frames per second
   * Update when replacing placeholder with actual asset
   */
  frameRate: 0,
};

/**
 * Helper function to validate if confetti assets are loaded
 * Used by ConfettiManager to check if data is available
 *
 * @returns {Object} Validation status
 */
export function validateConfettiAssets() {
  const validation = {
    hasImage: CONFETTI_SPRITESHEET.imageBase64.length > 0,
    hasFrameWidth: CONFETTI_SPRITESHEET.frameWidth > 0,
    hasFrameHeight: CONFETTI_SPRITESHEET.frameHeight > 0,
    hasConfettiAudio: CONFETTI_AUDIO.confettiSfxBase64.length > 0,
    hasVictoryAudio: CONFETTI_AUDIO.victorySfxBase64.length > 0,
  };

  validation.isComplete =
    validation.hasImage &&
    validation.hasFrameWidth &&
    validation.hasFrameHeight &&
    validation.hasConfettiAudio &&
    validation.hasVictoryAudio;

  validation.missingFields = [];
  if (!validation.hasImage) validation.missingFields.push("imageBase64");
  if (!validation.hasFrameWidth) validation.missingFields.push("frameWidth");
  if (!validation.hasFrameHeight) validation.missingFields.push("frameHeight");
  if (!validation.hasConfettiAudio)
    validation.missingFields.push("confettiSfxBase64");
  if (!validation.hasVictoryAudio)
    validation.missingFields.push("victorySfxBase64");

  return validation;
}

/**
 * Helper function to validate if coin celebration assets are loaded
 * Used by CoinCelebrationManager to check if data is available
 *
 * @returns {Object} Validation status
 */
export function validateCoinAssets() {
  const validation = {
    hasImage: COIN_SPRITESHEET.imageBase64.length > 0,
    hasFrameWidth: COIN_SPRITESHEET.frameWidth > 0,
    hasFrameHeight: COIN_SPRITESHEET.frameHeight > 0,
  };

  validation.isComplete =
    validation.hasImage &&
    validation.hasFrameWidth &&
    validation.hasFrameHeight;

  validation.missingFields = [];
  if (!validation.hasImage) validation.missingFields.push("imageBase64");
  if (!validation.hasFrameWidth) validation.missingFields.push("frameWidth");
  if (!validation.hasFrameHeight) validation.missingFields.push("frameHeight");

  return validation;
}

/**
 * Development/Debug: Log current asset status
 * Call this in console to check what's missing
 */
export function debugAssetStatus() {
  const validation = validateConfettiAssets();

  console.group("🎉 Confetti Assets Status");
  console.log("Image Spritesheet:", validation.hasImage ? "✅" : "❌");
  console.log("Frame Width:", validation.hasFrameWidth ? "✅" : "❌");
  console.log("Frame Height:", validation.hasFrameHeight ? "✅" : "❌");
  console.log("Confetti Audio:", validation.hasConfettiAudio ? "✅" : "❌");
  console.log("Victory Audio:", validation.hasVictoryAudio ? "✅" : "❌");
  console.log(
    "\nStatus:",
    validation.isComplete ? "READY ✅" : "INCOMPLETE ❌",
  );

  if (!validation.isComplete) {
    console.warn("Missing fields:", validation.missingFields.join(", "));
  }

  console.groupEnd();

  return validation;
}
